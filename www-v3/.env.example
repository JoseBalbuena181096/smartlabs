# SmartLabs v3 - copy to .env and fill values

# --- Postgres ---
POSTGRES_DB=smartlabs
POSTGRES_USER=smartlabs
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433

# --- Backend ---
BACKEND_PORT=8001
JWT_SECRET=please-change-me-in-prod
JWT_ALGO=HS256
JWT_EXPIRE_MINUTES=720

# --- MQTT (broker EMQX existente del stack viejo) ---
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_USER=jose
MQTT_PASSWORD=public
MQTT_CLIENT_ID=smartlabs-v3-backend

# --- nginx ---
NGINX_PORT=8090

# --- Loan defaults ---
LOAN_DUE_HOURS=8
INACTIVITY_TIMEOUT_SECONDS=180

# --- Face recognition ---
# RTSP de la Tapo C210 (cambiar IP, usuario, contraseña). stream2 es 480p.
RTSP_URL=rtsp://user:pass@192.168.0.50:554/stream2
# Token compartido backend ↔ face-service (header X-Service-Token).
FACE_SERVICE_TOKEN=change-me-face-service-token
# 0.6 balance recomendado; 0.7 más estricto, 0.5 más permisivo.
FACE_SIMILARITY_THRESHOLD=0.6
# Puerto expuesto del face-service (snapshot/health/debug).
FACE_SERVICE_PORT=8500
