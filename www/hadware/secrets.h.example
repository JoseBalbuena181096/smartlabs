// SMARTLABS · template de credenciales para los esp32_*.cpp
// ---------------------------------------------------------
// 1. Copia este archivo a "secrets.h" en la misma carpeta.
// 2. Completa con los valores reales (NO commitearlos a git — secrets.h
//    está en .gitignore).
// 3. Re-flashea cada estación.
//
// Si compilas con Arduino IDE, asegurate de que secrets.h esté en la misma
// carpeta del .ino abierto (Arduino agrega los .h del sketch automáticamente).

#pragma once

#define SECRETS_WIFI_SSID      "CAMBIAR_SSID"
#define SECRETS_WIFI_PASSWORD  "CAMBIAR_PASSWORD"

#define SECRETS_MQTT_HOST      "192.168.0.100"
#define SECRETS_MQTT_PORT      1883
#define SECRETS_MQTT_USER      "CAMBIAR_USUARIO"
#define SECRETS_MQTT_PASS      "CAMBIAR_PASSWORD"
